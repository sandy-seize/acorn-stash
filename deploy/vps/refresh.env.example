# acorn-stash 토스 시세 갱신 러너 — VPS 환경변수.
# 이 파일을 프로젝트 루트 .env.local 로 복사해 실제 값으로 채우세요.
#   cp deploy/vps/refresh.env.example .env.local && nano .env.local
#
# ⚠️ .env.local 은 gitignore 됨. 절대 커밋 금지.

# Neon (em-research 와 공유, vr_* 만 사용). Vercel 의 DATABASE_URL 과 동일 값.
DATABASE_URL=postgres://...

# 토스 Open API 키. 이 VPS 의 고정 IP 가 토스 콘솔 allowlist 에 등록돼 있어야 함.
TOSS_API_KEY=tsck_live_...
TOSS_SECRET_KEY=...

# VPS 자체 IP 가 allowlist 라 프록시 불필요(비워둠). 별도 프록시 경유 시에만 설정.
# TOSS_HTTPS_PROXY=
